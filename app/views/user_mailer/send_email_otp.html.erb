<!-- app/views/user_mailer/send_email_otp.html.erb -->

<div style="max-width:600px;margin:0 auto;font-family:Arial,sans-serif;background:#ffffff;border:1px solid #e5e7eb;border-radius:12px;overflow:hidden;">

  <!-- Header -->
  <div style="background:#0f172a;padding:20px;text-align:center;">
	  <img
	    src="https://res.cloudinary.com/siddtec/image/upload/v1780119650/logo_ykgx8y.png"
	    alt="QuickCred Logo"
	    style="width:90px;height:auto;display:block;margin:0 auto;">
 </div>

  <!-- Content -->
  <div style="padding:40px 30px;">

    <h2 style="margin:0 0 20px;color:#111827;">
      Hello <%= @user.first_name %>,
    </h2>

    <p style="font-size:16px;color:#4b5563;line-height:1.6;">
      We received a request to verify your login to your QuickCred account.
      Please use the OTP below to complete your verification.
    </p>

    <!-- OTP Box -->
    <div style="text-align:center;margin:35px 0;">
      <div style="
        display:inline-block;
        background:#f8fafc;
        border:2px dashed #2563eb;
        border-radius:10px;
        padding:18px 35px;
        font-size:34px;
        font-weight:bold;
        color:#2563eb;
        letter-spacing:8px;">
        <%= @otp %>
      </div>
    </div>

    <p style="font-size:15px;color:#ef4444;font-weight:600;">
      This OTP is valid for 10 minutes.
    </p>

    <p style="font-size:15px;color:#6b7280;line-height:1.6;">
      If you did not request this OTP, please ignore this email.
      No further action is required.
    </p>

    <hr style="border:none;border-top:1px solid #e5e7eb;margin:30px 0;">

    <p style="font-size:15px;color:#374151;">
      Thank you,<br>
      <strong>QuickCred Team</strong>
    </p>

  </div>

  <!-- Footer -->
  <div style="
    background:#f8fafc;
    padding:15px;
    text-align:center;
    font-size:12px;
    color:#9ca3af;">
    © <%= Time.current.year %> QuickCred. All rights reserved.
  </div>

</div>